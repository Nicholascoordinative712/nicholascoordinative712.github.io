import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { PROJECTS_DATA } from '../data/projects.js';
import { PROJECT_TRANSLATIONS } from '../data/translations.js';

interface Props {
  lang: 'en' | 'ru' | 'de';
}

const { lang } = Astro.props;

// Fetch all posts from content collections, filter by language, and sort
const posts = await getCollection('blog');
const langPosts = posts.filter(post => {
  if (lang === 'en') return !post.id.startsWith('ru/') && !post.id.startsWith('de/');
  return post.id.startsWith(`${lang}/`);
});
const targetPosts = langPosts.length > 0 ? langPosts : posts.filter(post => !post.id.startsWith('ru/') && !post.id.startsWith('de/'));
const sortedPosts = targetPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Helper to format date
const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
function formatFmDate(date: Date) {
  const d = String(date.getDate()).padStart(2, '0');
  const m = months[date.getMonth()];
  return `${m} ${d} 12:00`;
}

const sizeMap: Record<string, string> = {
  'vscode-agents': '5.2 KB',
  'dotnet-support-end': '3.6 KB',
  'wsl-containers': '4.8 KB'
};

const getLocalizedPath = (path: string) => lang === 'en' ? path : `/${lang}${path === '/' ? '' : path}`;

const articlesData = sortedPosts.map(post => {
  const baseId = post.id.replace(/^(ru|de)\//, '');
  return {
    href: getLocalizedPath(`/blog/${baseId}`),
    filename: `${baseId}.md`,
    size: sizeMap[baseId] || '3.5 KB',
    date: formatFmDate(post.data.pubDate),
    status: 'PUB',
    category: post.data.category,
    title: post.data.title,
    desc: post.data.description,
    image: post.data.image,
    readTime: post.data.readTime
  };
});

function resolveSinglePath(src: string, project: any) {
  if (!src || src.startsWith('http://') || src.startsWith('https://') || src.startsWith('data:')) {
    if (src && src.startsWith('https://github.com/') && src.includes('/blob/')) {
      return src.replace('/blob/', '/raw/');
    }
    return src;
  }
  const baseRepo = project.github.replace(/\/$/, "");
  const baseRaw = baseRepo.replace("github.com", "raw.githubusercontent.com") + "/main/";
  const cleanSrc = src.replace(/^\.\//, "");
  return baseRaw + cleanSrc;
}

function getFirstImageFromMarkdown(md: string, project: any) {
  if (!md) return '';
  const mdMatches = md.matchAll(/!\[.*?\]\((.*?)\)/g);
  for (const match of mdMatches) {
    const src = match[1];
    if (src && !src.toLowerCase().includes('.svg')) {
      return resolveSinglePath(src, project);
    }
  }
  const htmlMatches = md.matchAll(/<img[^>]*?src=["'](.*?)["']/g);
  for (const match of htmlMatches) {
    const src = match[1];
    if (src && !src.toLowerCase().includes('.svg')) {
      return resolveSinglePath(src, project);
    }
  }
  return '';
}

// Accent colors list for retro card headers
const accents = ['#36c5f0', '#aaabab', '#ecb22e', '#e01e5a', '#2eb67d', '#aaabab', '#ecb22e', '#e01e5a', '#36c5f0', '#aaabab', '#3a2418'];

