---
interface Props {
	title: string;
	description?: string;
	activeTab?: string;
}

const { title, description = "Alex is a software engineer building lightweight desktop tools, localizations, and mobile apps.", activeTab = "index" } = Astro.props;
import '../styles/global.css';
import { UI_TRANSLATIONS } from '../data/translations.js';

const pathname = Astro.url.pathname;
let currentLang: 'en' | 'ru' | 'de' = 'en';
if (pathname.startsWith('/ru/') || pathname === '/ru') {
  currentLang = 'ru';
} else if (pathname.startsWith('/de/') || pathname === '/de') {
  currentLang = 'de';
}

const t = UI_TRANSLATIONS[currentLang];

function getLocalizedPath(path: string) {
  if (currentLang === 'en') return path;
  return `/${currentLang}${path === '/' ? '' : path}`;
}

function getPathForLang(lang: string) {
  const cleanPath = pathname.replace(/^\/(ru|de)(\/|$)/, '/');
  if (lang === 'en') return cleanPath;
  return `/${lang}${cleanPath === '/' ? '' : cleanPath}`;
}
---

<!DOCTYPE html>
<html lang={currentLang}>
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
	<meta name="theme-color" content="#ffffff" />
	<meta name="color-scheme" content="light dark" />
	<script is:inline>
		(function(){
			const themeDefault = "light";
			const themeToggle = true;
			try {
				document.documentElement.dataset.theme = themeToggle
					? localStorage.getItem("alex-theme") || themeDefault
					: themeDefault;
			} catch (e) {
				document.documentElement.dataset.theme = themeDefault;
			}
		})();
	</script>
	<meta name="format-detection" content="telephone=no" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="apple-touch-icon" href="/favicon.svg" />
	<title>{title}</title>
	<meta name="description" content={description} />
	<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
	<meta name="author" content="Alex" />
</head>
<body>
	<div class="canvas-bg"></div>

	<!-- Header Nav -->
	<header class="nav" id="nav">
		<div class="nav-left">
			<a href={getLocalizedPath('/')} class="logo" aria-label="Almanex home">Almanex<span class="logo-dot">.</span></a>
			<a href={getLocalizedPath('/')} class={`navlink ${activeTab === 'index' ? 'active' : ''}`}>{t["nav.home"]}</a>
			<a href={getLocalizedPath('/work')} class={`navlink ${activeTab === 'work' ? 'active' : ''}`}>{t["nav.projects"]}</a>
			<a href={getLocalizedPath('/blog')} class={`navlink ${activeTab === 'blog' ? 'active' : ''}`}>{t["nav.blog"]}</a>
			<a href={getLocalizedPath('/about')} class={`navlink ${activeTab === 'about' ? 'active' : ''}`}>{t["nav.about"]}</a>
		</div>
		<div class="nav-right">
			<button class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
				<svg class="ic-moon" viewBox="0 0 24 24" fill="none"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path></svg>
				<svg class="ic-sun" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8"></circle><path d="M12 2.5v2M12 19.5v2M4.6 4.6l1.4 1.4M18 18l1.4 1.4M2.5 12h2M19.5 12h2M4.6 19.4l1.4-1.4M18 6l1.4-1.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg>
			</button>
			<a href={getLocalizedPath('/contact')} class={`btn-contact ${activeTab === 'contact' ? 'active' : ''}`}>
				<svg class="heart-ic" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg> {t["nav.contact"]}
			</a>
			<button class="nav-burger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="nav-mobile">
				<span></span><span></span><span></span>
			</button>
		</div>
		<!-- Language selector floating below header on both desktop and mobile -->
		<div class="header-lang-float">
			<a href={getPathForLang('en')} class={currentLang === 'en' ? 'lang-toggle-btn active' : 'lang-toggle-btn'}>EN</a>
			<a href={getPathForLang('ru')} class={currentLang === 'ru' ? 'lang-toggle-btn active' : 'lang-toggle-btn'}>RU</a>
			<a href={getPathForLang('de')} class={currentLang === 'de' ? 'lang-toggle-btn active' : 'lang-toggle-btn'}>DE</a>
		</div>
		<nav class="nav-mobile" id="nav-mobile" aria-label="Mobile navigation">
			<a href={getLocalizedPath('/')} class={`m-link ${activeTab === 'index' ? 'active' : ''}`}>{t["nav.home"]}</a>
			<a href={getLocalizedPath('/work')} class={`m-link ${activeTab === 'work' ? 'active' : ''}`}>{t["nav.projects"]}</a>
			<a href={getLocalizedPath('/blog')} class={`m-link ${activeTab === 'blog' ? 'active' : ''}`}>{t["nav.blog"]}</a>
			<a href={getLocalizedPath('/about')} class={`m-link ${activeTab === 'about' ? 'active' : ''}`}>{t["nav.about"]}</a>
			<a href={getLocalizedPath('/contact')} class={`m-contact ${activeTab === 'contact' ? 'active' : ''}`}>{t["nav.contact"]}</a>
		</nav>
	</header>

	<main id="main">
		<slot />
	</main>

	<!-- Footer terminal -->
	<footer class="ft">
		<div class="ft-card">
			<div class="terminal-window">
				<div class="terminal-header" style="background:var(--bar) !important; border-bottom:2px solid var(--ink) !important; padding:0 !important; display:flex !important; justify-content:space-between !important; align-items:stretch !important; height:42px !important; overflow:hidden !important; user-select:none !important;">
					<div class="terminal-tabs" style="display:flex !important; align-items:flex-end !important; flex-grow:1 !important; padding-left:10px !important; height:100% !important;">
						<a href={getLocalizedPath('/')} class={`term-tab ${activeTab === 'index' ? 'active-tab' : ''}`} style="display:flex !important; align-items:center !important; gap:6px !important; padding:0 16px !important; height:32px !important; text-decoration:none !important; margin-right:4px !important; font-size:12px !important; font-weight:bold !important; font-family:var(--font-mono) !important;">
							home.sh
						</a>
						<a href={getLocalizedPath('/work')} class={`term-tab ${activeTab === 'work' ? 'active-tab' : ''}`} style="display:flex !important; align-items:center !important; gap:6px !important; padding:0 16px !important; height:32px !important; text-decoration:none !important; margin-right:4px !important; font-size:12px !important; font-weight:bold !important; font-family:var(--font-mono) !important;">
							projects.exe
						</a>
						<a href={getLocalizedPath('/blog')} class={`term-tab ${activeTab === 'blog' ? 'active-tab' : ''}`} style="display:flex !important; align-items:center !important; gap:6px !important; padding:0 16px !important; height:32px !important; text-decoration:none !important; margin-right:4px !important; font-size:12px !important; font-weight:bold !important; font-family:var(--font-mono) !important;">
							blog.txt
						</a>
						<a href={getLocalizedPath('/about')} class={`term-tab ${activeTab === 'about' ? 'active-tab' : ''}`} style="display:flex !important; align-items:center !important; gap:6px !important; padding:0 16px !important; height:32px !important; text-decoration:none !important; margin-right:4px !important; font-size:12px !important; font-weight:bold !important; font-family:var(--font-mono) !important;">
							about.sys
						</a>
						<a href={getLocalizedPath('/contact')} class={`term-tab ${activeTab === 'contact' ? 'active-tab' : ''}`} style="display:flex !important; align-items:center !important; gap:6px !important; padding:0 16px !important; height:32px !important; text-decoration:none !important; margin-right:4px !important; font-size:12px !important; font-weight:bold !important; font-family:var(--font-mono) !important;">
							contact.bat
						</a>
						<a href="/bsod" title="Open New Tab" style="display:flex !important; align-items:center !important; justify-content:center !important; width:28px !important; height:28px !important; border:2px solid transparent !important; border-radius:6px !important; font-family:var(--font-mono) !important; font-size:16px !important; font-weight:bold !important; text-decoration:none !important; color:var(--ink) !important; margin-left:6px !important; margin-bottom:2px !important; transition:background 0.15s !important;">
							+
						</a>
						<div class="lang-tabs-spacer" style="flex-grow: 1;"></div>
						<a href={getPathForLang('en')} class={`term-tab footer-lang-tab ${currentLang === 'en' ? 'active-tab' : ''}`} style="display:flex !important; align-items:center !important; gap:6px !important; padding:0 12px !important; height:32px !important; text-decoration:none !important; margin-right:4px !important; font-size:11px !important; font-weight:bold !important; font-family:var(--font-mono) !important; border-color: var(--cyan) !important;">
							en.lang
						</a>
						<a href={getPathForLang('ru')} class={`term-tab footer-lang-tab ${currentLang === 'ru' ? 'active-tab' : ''}`} style="display:flex !important; align-items:center !important; gap:6px !important; padding:0 12px !important; height:32px !important; text-decoration:none !important; margin-right:4px !important; font-size:11px !important; font-weight:bold !important; font-family:var(--font-mono) !important; border-color: var(--cyan) !important;">
							ru.lang
						</a>
						<a href={getPathForLang('de')} class={`term-tab footer-lang-tab ${currentLang === 'de' ? 'active-tab' : ''}`} style="display:flex !important; align-items:center !important; gap:6px !important; padding:0 12px !important; height:32px !important; text-decoration:none !important; margin-right:12px !important; font-size:11px !important; font-weight:bold !important; font-family:var(--font-mono) !important; border-color: var(--cyan) !important;">
							de.lang
						</a>
					</div>
					<div class="terminal-win-controls" style="display:flex !important; align-items:center !important; padding-right:10px !important;">
						<button class="win-btn" aria-label="Minimize" style="background:none !important; border:none !important; color:var(--ink) !important; width:36px !important; height:100% !important; font-size:11px !important; cursor:pointer !important; display:flex !important; align-items:center !important; justify-content:center !important; transition:background 0.15s !important;">─</button>
						<button class="win-btn" aria-label="Maximize" style="background:none !important; border:none !important; color:var(--ink) !important; width:36px !important; height:100% !important; font-size:11px !important; cursor:pointer !important; display:flex !important; align-items:center !important; justify-content:center !important; transition:background 0.15s !important;">❑</button>
						<button class="win-btn win-close" aria-label="Close" style="background:none !important; border:none !important; color:var(--ink) !important; width:36px !important; height:100% !important; font-size:13px !important; cursor:pointer !important; display:flex !important; align-items:center !important; justify-content:center !important; transition:background 0.15s, color 0.15s !important;">✕</button>
					</div>
				</div>
				<div class="terminal-body dashboard-layout">
					<div class="dash-top-row">
						<div class="dash-col sys-info-col">
							<pre class="ascii-art">
   _   _    _____  __
  /_\ | |  | ___\ \/ /
 / _ \| |__| _|  >  < 
/_/ \_\____|____/_/\_\
							</pre>
							<div class="sys-specs">
								<p><span class="label">STATUS:</span> <span class="sys-status">ONLINE</span></p>
								<p><span class="label">UPTIME:</span> 24d 13h 42m</p>
								<p><span class="label">MEMORY:</span> 1.04 GB / 16.00 GB</p>
								<p><span class="label">OS_VER:</span> 1.0.4</p>
							</div>
						</div>
						<div class="dash-col logs-col">
							<h5>[SYS_LOGS]</h5>
							<div class="logs-window">
								<p><span class="timestamp">[ 0.00s ]</span> Initializing Almanex Core...</p>
