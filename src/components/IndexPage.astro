                  <div class="fm-big-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:48px; height:48px; opacity:0.35;"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg></div>
                  <div id="fm-empty-text">{l.fmHoverPreview}</div>
                  <div style="margin-top: 6px; font-size: 11px; opacity: 0.6;">
                    <span class="fm-cursor-blink">█</span> <span id="fm-waiting-text">{l.fmWaiting}</span>
                  </div>
                </div>

                <!-- Dynamic Preview -->
                <div class="fm-preview-content" id="fm-dynamic-preview">
                  <img class="fm-preview-img" id="fm-prev-img" src="" alt="" loading="lazy">
                  <div class="fm-preview-body">
                    <span class="fm-preview-cat" id="fm-prev-cat"></span>
                    <span class="fm-preview-date" id="fm-prev-date"></span>
                    <h3 class="fm-preview-title" id="fm-prev-title"></h3>
                    <p class="fm-preview-desc" id="fm-prev-desc"></p>
                    <div class="fm-preview-meta">
                      <span id="fm-prev-readtime"></span>
                      <span id="fm-prev-filename"></span>
                    </div>
                    <a class="fm-preview-action" id="fm-prev-action" href="">F3 View →</a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- F-Key Command Bar -->
          <div class="fm-cmdbar">
            <div class="fm-cmdbar-item"><span class="fm-fkey">F1</span><span class="fm-flabel">Help</span></div>
            <div class="fm-cmdbar-item"><span class="fm-fkey">F3</span><span class="fm-flabel">View</span></div>
            <div class="fm-cmdbar-item"><span class="fm-fkey">F4</span><span class="fm-flabel">Edit</span></div>
            <div class="fm-cmdbar-item" id="fm-f5-btn" style="cursor:pointer; background: var(--cyan-soft) !important;"><span class="fm-fkey" style="background: var(--cyan) !important; color: #111212 !important;">F5</span><span class="fm-flabel" style="color: var(--ink) !important; font-weight: bold !important;">PrevPg</span></div>
            <div class="fm-cmdbar-item" id="fm-f6-btn" style="cursor:pointer; background: var(--cyan-soft) !important;"><span class="fm-fkey" style="background: var(--cyan) !important; color: #111212 !important;">F6</span><span class="fm-flabel" style="color: var(--ink) !important; font-weight: bold !important;">NextPg</span></div>
            <div class="fm-cmdbar-item"><span class="fm-fkey">F7</span><span class="fm-flabel">MkDir</span></div>
            <div class="fm-cmdbar-item"><span class="fm-fkey">F8</span><span class="fm-flabel">Delete</span></div>
            <div class="fm-cmdbar-item"><span class="fm-fkey">F9</span><span class="fm-flabel">Menu</span></div>
            <div class="fm-cmdbar-item"><span class="fm-fkey">F10</span><span class="fm-flabel">Quit</span></div>
          </div>

          <!-- Status bar -->
          <div class="fm-statusbar">
            <span id="fm-status-info">{l.fmLoading}</span>
            <span id="fm-clock-status">—</span>
          </div>
        </div>
      </div>

      <div style="text-align: center; margin-top: 48px;">
        <a href={getLocalizedPath('/blog')} class="btn-view-blog" style="font-family: var(--font-mono); font-size: 13.5px; font-weight: 800; text-transform: uppercase; background: var(--surface); color: var(--ink); border: 2px solid var(--ink); border-radius: 14px; padding: 15px 30px; display: inline-flex; align-items: center; gap: 10px; box-shadow: 5px 5px 0px var(--ink); text-decoration: none; transition: all 0.2s cubic-bezier(0.23, 1, 0.32, 1);">
          <span>{l.blogExploreBtn}</span>
          <span style="background: var(--cyan); border: 1.5px solid var(--ink); border-radius: 6px; padding: 2px 8px; font-size: 11px;">{l.blogPostsCount}</span>
        </a>
      </div>
    </section>

    <section class="newsletter">
      <div class="newsletter-band">
        <div class="nl-inner">
          <p class="kicker">{l.newsletterKicker}</p>
          <h2>{l.newsletterTitle}</h2>
          <p class="sub">{l.newsletterSub}</p>
          <form class="nl-form" action="https://buttondown.email/api/emails/embed-subscribe/yourname" method="POST" target="_blank">
            <input type="email" name="email" placeholder={l.newsletterPlaceholder} required aria-label="Email address">
            <button type="submit">{l.newsletterBtn}</button>
          </form>
          <p class="nl-note">{l.newsletterNote}</p>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script is:inline define:vars={{ articlesData, l }}>
  (function() {
    const ARTICLES = articlesData;

    const DECORATIVE = [
      { type: 'dir', name: `${l.fmDrafts}/`, size: '<DIR>', date: 'Jul 08 18:22', status: '—' },
      { type: 'draft', name: 'README.md', size: '1.2 KB', date: 'Jun 15 08:00', status: l.fmDraft, opacity: 0.55 },
      { type: 'cfg', name: '.blogrc', size: '0.4 KB', date: 'Jun 01 10:00', status: l.fmConfig, opacity: 0.55 }
    ];

    const ITEMS_PER_PAGE = 3;
    let currentPage = 0;
    let selectedIndexOnPage = -1;

    const fileList = document.getElementById('fm-file-list');
    if (!fileList) return;

    const panelDir = document.getElementById('fm-panel-dir');
    const statusInfo = document.getElementById('fm-status-info');
    const clockStatus = document.getElementById('fm-clock-status');

    const previewEmpty = document.getElementById('fm-preview-empty');
    const dynamicPreview = document.getElementById('fm-dynamic-preview');
    const prevImg = document.getElementById('fm-prev-img');
    const prevCat = document.getElementById('fm-prev-cat');
    const prevDate = document.getElementById('fm-prev-date');
    const prevTitle = document.getElementById('fm-prev-title');
    const prevDesc = document.getElementById('fm-prev-desc');
    const prevReadtime = document.getElementById('fm-prev-readtime');
    const prevFilename = document.getElementById('fm-prev-filename');
    const prevAction = document.getElementById('fm-prev-action');

    const f5Btn = document.getElementById('fm-f5-btn');
    const f6Btn = document.getElementById('fm-f6-btn');

    const totalPages = Math.ceil(ARTICLES.length / ITEMS_PER_PAGE);

    function getPageArticles() {
      const start = currentPage * ITEMS_PER_PAGE;
      return ARTICLES.slice(start, start + ITEMS_PER_PAGE);
    }

    function showPreview(article) {
      if (article) {
        if (previewEmpty) previewEmpty.style.display = 'none';
        if (dynamicPreview) dynamicPreview.classList.add('is-visible');

        if (prevImg) {
          prevImg.src = article.image;
          prevImg.alt = article.title;
        }
        if (prevCat) prevCat.textContent = article.category;
        if (prevDate) prevDate.textContent = article.date;
        if (prevTitle) prevTitle.textContent = article.title;
        if (prevDesc) prevDesc.textContent = article.desc;
        if (prevReadtime) prevReadtime.textContent = `read_time: ${article.readTime}`;
        if (prevFilename) prevFilename.textContent = article.filename;
        if (prevAction) {
          prevAction.href = article.href;
          prevAction.textContent = 'F3 View →';
        }
      } else {
        if (dynamicPreview) dynamicPreview.classList.remove('is-visible');
        if (previewEmpty) previewEmpty.style.display = '';
      }
    }

    function render() {
      fileList.innerHTML = '';
      const pageArticles = getPageArticles();

      // 1. Render static '..' entry
      const parentRow = document.createElement('div');
      parentRow.className = 'fm-file-row fm-dir';
      parentRow.dataset.type = 'dir';
      parentRow.innerHTML = `
        <span class="fm-filename"><span class="fm-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px; height:14px; display:inline-block; vertical-align:middle; margin-right:4px;"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></span> ..</span>
        <span>&lt;DIR&gt;</span>
        <span>Jul 10 10:58</span>
        <span>—</span>
      `;
      fileList.appendChild(parentRow);

      // 2. Render articles on current page
      pageArticles.forEach((art, pageIdx) => {
        const artRow = document.createElement('a');
        artRow.className = 'fm-file-row';
        artRow.href = art.href;
        artRow.dataset.type = 'article';
        artRow.dataset.pageIndex = String(pageIdx);
        if (pageIdx === selectedIndexOnPage) {
          artRow.classList.add('is-selected');
        }

        artRow.innerHTML = `
          <span class="fm-filename"><span class="fm-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px; height:14px; display:inline-block; vertical-align:middle; margin-right:4px;"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg></span> ${art.filename}</span>
          <span>${art.size}</span>
          <span>${art.date}</span>
          <span class="fm-status fm-status-pub">● ${art.status}</span>
        `;

        artRow.addEventListener('mouseenter', () => {
          showPreview(art);
          const rows = fileList.querySelectorAll('.fm-file-row');
          rows.forEach(r => r.classList.remove('is-selected'));
          artRow.classList.add('is-selected');
        });

        artRow.addEventListener('mouseleave', () => {
          if (selectedIndexOnPage !== pageIdx) {
            artRow.classList.remove('is-selected');
          }
          restoreSelectedPreview();
        });

        artRow.addEventListener('click', () => {
          selectedIndexOnPage = pageIdx;
          restoreSelectedPreview();
        });

        fileList.appendChild(artRow);
      });

      // 3. Render decorative files (only on page 0)
      if (currentPage === 0) {
        DECORATIVE.forEach(item => {
          const decRow = document.createElement('div');
          decRow.className = 'fm-file-row' + (item.type === 'dir' ? ' fm-dir' : '');
          if (item.opacity) decRow.style.opacity = String(item.opacity);
          decRow.dataset.type = 'decorative';
          decRow.innerHTML = `
            <span class="fm-filename"><span class="fm-icon">${item.type === 'dir' ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px; height:14px; display:inline-block; vertical-align:middle; margin-right:4px;"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>' : item.type === 'draft' ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px; height:14px; display:inline-block; vertical-align:middle; margin-right:4px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>' : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px; height:14px; display:inline-block; vertical-align:middle; margin-right:4px;"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>'}</span> ${item.name}</span>
            <span>${item.size}</span>
            <span>${item.date}</span>
            <span style="color:var(--gray);">${item.status}</span>
          `;
          fileList.appendChild(decRow);
        });
      }

      if (panelDir) panelDir.textContent = `/home/alex/blog/ [Page ${currentPage + 1}/${totalPages || 1}]`;

      const totalKB = pageArticles.reduce((sum, art) => sum + parseFloat(art.size), 0).toFixed(1);
      if (statusInfo) statusInfo.textContent = `${ARTICLES.length} ${l.fmFiles}, ${totalPages} ${l.fmPages} — ${totalKB} KB ${l.fmKBOnPage}`;

      restoreSelectedPreview();
    }

    function restoreSelectedPreview() {
      const rows = fileList.querySelectorAll('.fm-file-row');
      rows.forEach(r => r.classList.remove('is-selected'));

      const pageArticles = getPageArticles();
      if (selectedIndexOnPage >= 0 && selectedIndexOnPage < pageArticles.length) {
        const art = pageArticles[selectedIndexOnPage];
        showPreview(art);
        const activeRow = fileList.querySelector(`.fm-file-row[data-page-index="${selectedIndexOnPage}"]`);
        if (activeRow) activeRow.classList.add('is-selected');
      } else {
        showPreview(null);
      }
    }

    function nextPage() {
      if (currentPage < totalPages - 1) {
        currentPage++;
        selectedIndexOnPage = -1;
        render();
      }
    }

    function prevPage() {
      if (currentPage > 0) {
        currentPage--;
        selectedIndexOnPage = -1;
        render();
      }
    }

    if (f5Btn) f5Btn.addEventListener('click', prevPage);
    if (f6Btn) f6Btn.addEventListener('click', nextPage);

    document.addEventListener('keydown', (e) => {
      const rect = fileList.getBoundingClientRect();
      const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
      if (!isVisible) return;

      const pageArticles = getPageArticles();

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIndexOnPage = Math.min(selectedIndexOnPage + 1, pageArticles.length - 1);
        restoreSelectedPreview();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIndexOnPage = Math.max(selectedIndexOnPage - 1, 0);
        restoreSelectedPreview();
      } else if (e.key === 'Enter' && selectedIndexOnPage >= 0) {
        const art = pageArticles[selectedIndexOnPage];
        if (art && art.href) window.location.href = art.href;
      } else if (e.key === 'F5') {
        e.preventDefault();
        prevPage();
      } else if (e.key === 'F6') {
        e.preventDefault();
        nextPage();
      }
    });

    if (clockStatus) {
      const tick = () => {
        const d = new Date();
        const h = String(d.getHours()).padStart(2, '0');
        const m = String(d.getMinutes()).padStart(2, '0');
        const s = String(d.getSeconds()).padStart(2, '0');
        clockStatus.textContent = h + ':' + m + ':' + s;
      };
      tick();
      setInterval(tick, 1000);
    }

    render();
  })();
</script>

<script is:inline>
  (() => {
    // Live hero clock
    const clock = document.getElementById("clock");
    if (clock) {
      const tick = () => {
        const d = new Date();
        const h = String(d.getHours()).padStart(2, "0");
        const m = String(d.getMinutes()).padStart(2, "0");
        const s = String(d.getSeconds()).padStart(2, "0");
        clock.textContent = h + ":" + m + ":" + s;
      };
      tick();
      setInterval(tick, 1000);
    }

    // Dynamic repository rotation
    const stack = document.getElementById("stack");
    if (stack) {
      const cards = Array.from(stack.querySelectorAll(".folder-card"));
      if (cards.length > 0) {
        const mapped = cards.map((card, idx) => ({ card, idx }));
        const shuffled = mapped.sort(() => 0.5 - Math.random());
        const selected = shuffled.slice(0, 4);
        selected.sort((a, b) => a.idx - b.idx);
        selected.forEach((item, index) => {
          item.card.style.display = "block";
          item.card.style.zIndex = String(index + 1);
        });
      }
    }

    // Dynamic mechanical keyboard background grid (Realistic 1800 Compact Layout)
    const backdrop = document.getElementById("keyboard-backdrop");
    if (backdrop) {
      const fragment = document.createDocumentFragment();
      const keys = [];
      const skipped = new Set();

      const skip = (r, c) => skipped.add(`${r},${c}`);
      const createKeycap = (label, w, h, opacity) => {
        const el = document.createElement("div");
        el.className = "bg-keycap";
        el.style.width = `${w}px`;
        el.style.height = `${h}px`;
        el.style.opacity = String(opacity);

        const span = document.createElement("span");
        span.className = "bg-keycap-label";
        span.textContent = label;
        el.appendChild(span);
        return el;
      };

      // Key mappings matching the compact laptop keyboard layout
      const keyMap = {
        "-1": {
          "-6": "7", "-5": "8", "-4": "9", "-3": "0", "-2": "-", "-1": "=",
          // Backspace spans c=0, 1
          "2": "NUM", "3": "/", "4": "*", "5": "-"
        },
        "0": {
          "-6": "U", "-5": "I", "-4": "O", "-3": "P", "-2": "[", "-1": "]",
          // Enter top spans c=0, 1
          "2": "7", "3": "8", "4": "9" // c=5 is vertical +
        },
        "1": {
          "-7": "J", "-6": "K", "-5": "L", "-4": ";", "-3": "'", "-2": "\\",
          // Enter bottom spans c=-1, 0, 1
          "2": "4", "3": "5", "4": "6" // c=5 is vertical + (skipped)
        },
        "2": {
          "-7": "B", "-6": "N", "-5": "M", "-4": ",", "-3": ".", "-2": "/",
          // Right Shift spans c=-1, 0, 1
          "2": "1", "3": "2", "4": "3" // c=5 is vertical Enter
        },
        "3": {
          // Spacebar spans c=-7, -6, -5, -4
          "-3": "ALT", "-2": "CTRL",
          "-1": "◀", "0": "▲▼", "1": "▶", // Arrow cluster
          // Numpad 0 spans c=2, 3
          "4": "." // c=5 is vertical Enter (skipped)
        }
      };

      // 1. ISO Enter covers:
      // r=0: c=0, 1 (top narrower section)
      // r=1: c=-1, 0, 1 (bottom wider section)
      skip(0, 0); skip(0, 1);
      skip(1, -1); skip(1, 0); skip(1, 1);

      // 2. Custom wide and vertical keycaps:
      
      // Right Shift: at r=2, c=-1 (spans c=-1, 0, 1) -> width 166px (fits under bottom of Enter)
      const renderShift = () => {
        const key = createKeycap('SHIFT', 166, 42, 0.62);
        key.style.left = `calc(50% + ${-1 * 58 - 25}px)`;
        key.style.top = `calc(50% + ${2 * 50 - 21}px)`;
        fragment.appendChild(key);
        keys.push({ element: key, baseOpacity: 0.62 });
        skip(2, -1); skip(2, 0); skip(2, 1);
      };
      renderShift();

      // Backspace: at r=-1, c=0 (spans c=0, 1) -> width 108px (fits above top of Enter)
      const renderBackspace = () => {
        const key = createKeycap('←', 108, 42, 0.66);
        key.style.left = `calc(50% + ${0 * 58 - 25}px)`;
        key.style.top = `calc(50% + ${-1 * 50 - 21}px)`;
        fragment.appendChild(key);
        keys.push({ element: key, baseOpacity: 0.66 });
        skip(-1, 0); skip(-1, 1);
      };
      renderBackspace();

      // Spacebar: at r=3, c=-7 (spans c=-7, -6, -5, -4) -> width 224px (extended by 1 key width)
      const renderSpacebar = () => {
        const key = createKeycap('SPACE', 224, 42, 0.58);
        key.style.left = `calc(50% + ${-7 * 58 - 25}px)`;
        key.style.top = `calc(50% + ${3 * 50 - 21}px)`;
        fragment.appendChild(key);
        keys.push({ element: key, baseOpacity: 0.58 });
        skip(3, -7); skip(3, -6); skip(3, -5); skip(3, -4);
      };
      renderSpacebar();

      // Numpad 0: at r=3, c=2 (spans c=2, 3) -> width 108px (sits under Numpad 1 and 2)
      const renderNumpad0 = () => {
        const key = createKeycap('0', 108, 42, 0.42);
        key.style.left = `calc(50% + ${2 * 58 - 25}px)`;
        key.style.top = `calc(50% + ${3 * 50 - 21}px)`;
        fragment.appendChild(key);
        keys.push({ element: key, baseOpacity: 0.42 });
        skip(3, 2); skip(3, 3);
      };
      renderNumpad0();

      // Vertical Numpad +: at r=0, c=5 (spans r=0, 1) -> height 92px
      const renderNumpadPlus = () => {
        const key = createKeycap('+', 50, 92, 0.35);
        key.style.left = `calc(50% + ${5 * 58 - 25}px)`;
        key.style.top = `calc(50% + ${0 * 50 - 21}px)`;
        fragment.appendChild(key);
        keys.push({ element: key, baseOpacity: 0.35 });
        skip(0, 5); skip(1, 5);
      };
      renderNumpadPlus();

      // Vertical Numpad Enter: at r=2, c=5 (spans r=2, 3) -> height 92px
      const renderNumpadEnter = () => {
        const key = createKeycap('ENT', 50, 92, 0.3);
        key.style.left = `calc(50% + ${5 * 58 - 25}px)`;
        key.style.top = `calc(50% + ${2 * 50 - 21}px)`;
        fragment.appendChild(key);
        keys.push({ element: key, baseOpacity: 0.3 });
        skip(2, 5); skip(3, 5);
      };
      renderNumpadEnter();

      // 3. Render standard keycaps:
      for (let r = -1; r <= 3; r++) {
        for (let c = -7; c <= 5; c++) {
          if (skipped.has(`${r},${c}`)) continue;

          // Symmetric opacity: fades out to transparent towards both left and right edges
          const dist = Math.sqrt(c * c + r * r);
          const opacity = Math.max(0.04, 0.72 - dist * 0.095);

          const labelText = (keyMap[r] && keyMap[r][c]) || "";
          if (!labelText) continue;

          const key = createKeycap(labelText, 50, 42, opacity);
          key.style.left = `calc(50% + ${c * 58 - 25}px)`;
          key.style.top = `calc(50% + ${r * 50 - 21}px)`;

          fragment.appendChild(key);
          keys.push({ element: key, baseOpacity: opacity });
        }
      }
      backdrop.appendChild(fragment);

      // Random ghost typing simulation
      setInterval(() => {
        if (keys.length === 0) return;
        const randomKey = keys[Math.floor(Math.random() * keys.length)];
        randomKey.element.classList.add("bg-keycap-pressed");
        setTimeout(() => {
          randomKey.element.classList.remove("bg-keycap-pressed");
        }, 300);
      }, 1200);
    }
  })();
</script>

<style is:global>
  .enter-button-wrapper {
    position: relative !important;
    display: inline-flex !important;
    justify-content: center !important;
    align-items: center !important;
    width: 174px !important;
    height: 92px !important;
    margin-top: 36px !important;
    margin-left: 4px !important; /* Offset for right extension */
    z-index: 10 !important;
  }
  .keycap-iso-enter {
    width: 174px !important;
    top: 10px !important;
  }
  .keyboard-backdrop {
    position: absolute !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    width: 1400px !important;
    height: 600px !important;
    pointer-events: none !important;
    z-index: 1 !important;
    overflow: visible !important;
  }
  @media (max-width: 900px) {
