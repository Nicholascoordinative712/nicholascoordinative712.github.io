  <!-- Reboot simulation screen -->
  <div class="reboot-screen" id="reboot-screen">
    <div id="reboot-console"></div>
    <span class="cursor"></span>
  </div>

  <script is:inline>
    // Audio synthesis for glitchy BSOD hardware buzz
    function playGlitchSound() {
      try {
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        if (!AudioContext) return;
        const ctx = new AudioContext();
        
        // Short error alert tone
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(140, ctx.currentTime); // Low buzz
        osc.frequency.linearRampToValueAtTime(100, ctx.currentTime + 0.3);
        
        gain.gain.setValueAtTime(0.08, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.35);
        
        osc.connect(gain);
        gain.connect(ctx.destination);
        
        osc.start();
        osc.stop(ctx.currentTime + 0.35);
      } catch (e) {}
    }

    // Play initial buzz on interaction / load
    window.addEventListener('click', () => {
      playGlitchSound();
    }, { once: true });

    // Start progress counter
    const progressText = document.getElementById('progress-text');
    const container = document.getElementById('bsod-container');
    const rebootScreen = document.getElementById('reboot-screen');
    const rebootConsole = document.getElementById('reboot-console');
    
    let percent = 0;
    
    function updateProgress() {
      if (percent < 100) {
        percent += Math.floor(Math.random() * 8) + 2;
        if (percent > 100) percent = 100;
        progressText.textContent = percent + "% complete";
        
        if (Math.random() > 0.75) {
          container.classList.add('glitching');
          playGlitchSound();
          setTimeout(() => {
            container.classList.remove('glitching');
          }, 80);
        }
        
        setTimeout(updateProgress, Math.floor(Math.random() * 800) + 300);
      } else {
        setTimeout(reboot, 1000);
      }
    }
    
    setTimeout(updateProgress, 1200);

    window.addEventListener('keydown', () => {
      if (percent < 90) percent += 5;
      playGlitchSound();
    });
    
    window.addEventListener('click', () => {
      if (percent < 90) percent += 5;
    });

    const consoleLines = [
      "Phoenix ROM BIOS Plus Version 1.10 A05",
      "Copyright 1985-2026 Phoenix Technologies Ltd.",
      "All Rights Reserved",
      "",
      "CPU: Intel Core i9-14900K @ 3.20GHz",
      "Memory Test: 16384MB OK",
      "Detecting Primary Master ... [ Almanex SSD 1TB ]",
      "Detecting Primary Slave  ... [ None ]",
      "",
      "Booting from Hard Disk...",
      "Waking up the developer...",
      "Refilling coffee levels ... [ 100% OK ]",
      "Compiling portfolio.exe ... [ 0 errors, 1337 warnings ]",
      "Starting local web server..."
    ];

    function reboot() {
      container.style.display = 'none';
      rebootScreen.style.display = 'block';
      
      let lineIndex = 0;
      function printConsoleLine() {
        if (lineIndex < consoleLines.length) {
          const p = document.createElement('p');
          p.textContent = consoleLines[lineIndex];
          rebootConsole.appendChild(p);
          lineIndex++;
          try {
            const ctx = new (window.AudioContext || window.webkitAudioContext)();
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.frequency.value = 800;
            gain.gain.value = 0.005;
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start();
            osc.stop(ctx.currentTime + 0.05);
          } catch(e) {}
          
          setTimeout(printConsoleLine, Math.floor(Math.random() * 250) + 80);
        } else {
          setTimeout(() => {
            window.location.href = "/";
          }, 1200);
        }
      }
      
      setTimeout(printConsoleLine, 600);
    }
  </script>
</body>
</html>
