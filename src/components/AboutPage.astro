---
import Layout from '../layouts/Layout.astro';

interface Props {
  lang: 'en' | 'ru' | 'de';
}

const { lang } = Astro.props;

const aboutLabels = {
  en: {
    title: "About — Almanex",
    kicker: "about me!",
    heading: 'Engineer, <span class="about-avatar-inline"><img src="https://github.com/Almanex.png" alt="Almanex" /></span> tinkerer, developer',
    sub: "Developer building lightweight desktop tools, localizations, and mobile apps.",
    telKicker: "by the numbers // live telemetry",
    telTitle: "System Telemetry",
    telSub: "[ HARDWARE METRICS & REPOSITORY SNAPSHOT ]",
    codingYears: "Years Coding",
    codingDesc: "Architecting solutions & writing clean code across desktop and mobile platforms.",
    reposTitle: "Open Source Repos",
    reposDesc: "Lightweight desktop tools, scripts, & custom Windows system localizations.",
    langsTitle: "Core Languages",
    langsDesc: "Proficient across JS, Kotlin, Java, HTML/CSS, and shell automation scripts.",
    commitsTitle: "Commits / Year",
    commitsDesc: "Consistent contribution rate and continuous shipping across active branches.",
    histKicker: "the story so far // git commit log",
    histTitle: "How I got here",
    histSub: "[ BRANCH: refs/heads/main // VERSION HISTORICAL TIMELINE ]",
    t2026Title: "Open Source Developer",
    t2026Body: "Contributing to tools, libraries, and utility scripts directly on GitHub. Building modular developer setups, automated deployment workflows, and interactive open-source projects.",
    t2023Title: "Desktop tools & Localizations",
    t2023Body: "Created translation projects and utility setups for Windows 10/11 systems. Developed custom system optimization scripts, lightweight desktop helpers, and multi-language software adaptations.",
    t2020Title: "Mobile App Development",
    t2020Body: "Built native Android applications using Kotlin and Java for cataloging, location mapping, and utility management. Focused on responsive layouts, clean architecture, and efficient data handling.",
    t2016Title: "Started programming",
    t2016Body: "Wrote first lines of code and explored software architecture, terminal commands, and system configurations. Set the foundation for a lifelong passion in building fast, functional software tools.",
    t2010Title: "Web Design & Fullstack Development",
    t2010Body: "First steps in layouts, markup, and database integration. Designed corporate landing pages, custom content management scripts, and e-commerce templates.",
    statusAvail: "STATUS: Available",
    contactHeading: "Let's work together!",
    contactSub: "Open to software engineering roles, collaboration, and interesting conversations about system tools and code architectures.",
    contactBtnEmail: "hello@example.com",
    contactBtnGet: "Get in touch",
    responseLabel: "response",
    responseTime: "within ~48 hours"
  },
  ru: {
    title: "Обо мне — Almanex",
    kicker: "обо мне!",
    heading: 'Инженер, <span class="about-avatar-inline"><img src="https://github.com/Almanex.png" alt="Almanex" /></span> разработчик, энтузиаст',
    sub: "Разработчик, создающий легковесные десктопные инструменты, локализации и мобильные приложения.",
    telKicker: "в цифрах // живая телеметрия",
    telTitle: "Системная телеметрия",
    telSub: "[ АППАРАТНЫЕ МЕТРИКИ И АКТИВНОСТЬ РЕПОЗИТОРИЕВ ]",
    codingYears: "Лет кодинга",
    codingDesc: "Проектирование решений и написание чистого кода для настольных и мобильных платформ.",
    reposTitle: "Open Source проектов",
    reposDesc: "Легковесные десктопные утилиты, скрипты автоматизации и локализации систем.",
    langsTitle: "Ключевые языки",
    langsDesc: "Опыт работы с JS, Kotlin, Java, HTML/CSS и скриптами автоматизации shell/batch.",
    commitsTitle: "Коммитов / Год",
    commitsDesc: "Стабильный уровень вкладов в код и непрерывный деплой в активные ветки.",
    histKicker: "история изменений // git commit log",
    histTitle: "Как я пришел в IT",
    histSub: "[ ВЕТКА: refs/heads/main // ИСТОРИЧЕСКИЙ ТАЙМЛАЙН ВЕРСИЙ ]",
    t2026Title: "Open Source Разработчик",
    t2026Body: "Создание полезных инструментов, библиотек и утилит на GitHub. Настройка модульного окружения, процессов CI/CD и интерактивных веб-сервисов.",
    t2023Title: "Десктопный софт & Локализации",
    t2023Body: "Сборка проектов перевода и системных скриптов оптимизации для Windows 10/11. Разработка легковесных фоновых помощников.",
    t2020Title: "Мобильная разработка (Android)",
    t2020Body: "Создание нативных Android-приложений на Kotlin и Java: каталогизаторы, геолокационные сервисы. Фокус на адаптивном дизайне и чистой архитектуре.",
    t2016Title: "Первые шаги в кодинге",
    t2016Body: "Написание первых алгоритмов, изучение архитектуры ОС, команд терминала. Закладка фундамента для разработки эффективных инструментов.",
    t2010Title: "Веб-дизайн & Fullstack-разработка",
    t2010Body: "Проектирование интерфейсов, верстка и интеграция баз данных. Создание корпоративных сайтов и кастомных CMS решений.",
    statusAvail: "СТАТУС: Доступен",
    contactHeading: "Давайте работать вместе!",
    contactSub: "Открыт для интересных коммерческих предложений, совместных проектов и обсуждения архитектур кода.",
    contactBtnEmail: "hello@example.com",
    contactBtnGet: "Связаться со мной",
    responseLabel: "ответ",
    responseTime: "в течение ~48 часов"
  },
  de: {
    title: "Über mich — Almanex",
    kicker: "über mich!",
    heading: 'Ingenieur, <span class="about-avatar-inline"><img src="https://github.com/Almanex.png" alt="Almanex" /></span> Entwickler, Bastler',
    sub: "Entwickler, der leichtgewichtige Desktop-Tools, Lokalisierungen und mobile Apps baut.",
    telKicker: "in zahlen // live-telemetrie",
    telTitle: "System-Telemetrie",
    telSub: "[ HARDWARE-METRIKEN & REPOSITORY-SCHNAPPSCHUSS ]",
    codingYears: "Jahre Coding",
    codingDesc: "Architektur von Lösungen & Schreiben von sauberem Code auf Desktop- und Mobilplattformen.",
    reposTitle: "Open-Source-Repos",
    reposDesc: "Leichtgewichtige Desktop-Tools, Skripte & benutzerdefinierte Windows-Systemlokalisierungen.",
    langsTitle: "Kernsprachen",
    langsDesc: "Erfahren in JS, Kotlin, Java, HTML/CSS und Shell-Automatisierungsskripten.",
    commitsTitle: "Commits / Jahr",
    commitsDesc: "Konsistente Beitragsrate und kontinuierliches Shipping in aktiven Branches.",
    histKicker: "die geschichte bisher // git commit log",
    histTitle: "Mein Weg hierher",
    histSub: "[ BRANCH: refs/heads/main // HISTORISCHE TIMELINE DER VERSIONEN ]",
    t2026Title: "Open-Source-Entwickler",
    t2026Body: "Beiträge zu Tools, Bibliotheken und Hilfsskripten direkt auf GitHub. Aufbau modularer Entwickler-Setups, automatisierter Workflows und interaktiver Projekte.",
    t2023Title: "Desktop-Tools & Lokalisierungen",
    t2023Body: "Erstellung von Übersetzungsprojekten und Systemoptimierungsskripten für Windows 10/11. Entwicklung leichtgewichtiger Desktop-Helfer.",
    t2020Title: "Mobile App-Entwicklung",
    t2020Body: "Entwicklung nativer Android-Anwendungen mit Kotlin und Java für Kartierung, Katalogisierung und Utilities. Fokus auf responsive Layouts und saubere Architektur.",
    t2016Title: "Programmierung gestartet",
    t2016Body: "Schrieb erste Zeilen Code und erforschte Systemarchitektur, Terminalbefehle und Konfigurationen. Grundsteinlegung für schnelle, funktionale Tools.",
    t2010Title: "Webdesign & Fullstack-Entwicklung",
    t2010Body: "Erste Schritte in Layouts, Markup und Datenbankintegration. Entwarf Landingpages, benutzerdefinierte CMS-Skripte und E-Commerce-Vorlagen.",
    statusAvail: "STATUS: Verfügbar",
    contactHeading: "Lass uns zusammenarbeiten!",
    contactSub: "Offen für Software-Engineering-Rollen, Kooperationen und interessante Gespräche über System-Tools und Code-Architekturen.",
    contactBtnEmail: "hello@example.com",
    contactBtnGet: "Kontakt aufnehmen",
    responseLabel: "Antwortzeit",
    responseTime: "innerhalb von ~48 Stunden"
  }
};

const l = aboutLabels[lang];
const getLocalizedPath = (path: string) => lang === 'en' ? path : `/${lang}${path === '/' ? '' : path}`;
---

<Layout title={l.title} activeTab="about">
  <header class="page-header">
    <p class="kicker">about me!</p>
    <h1 set:html={l.heading}></h1>
    <p class="sub">{l.sub}</p>
  </header>

  <section class="section" id="stats" style="padding: 70px 0 60px;">
    <div class="section-head" style="margin-bottom: 48px;">
      <p class="kicker" style="font-family: var(--font-hand); font-size: 30px; transform: rotate(-3deg); display: inline-block; color: var(--magenta);">by the numbers // live telemetry</p>
      <h2 style="font-family: var(--font-display); font-size: clamp(34px, 5.2vw, 56px); font-weight: 900; letter-spacing: -0.03em; text-transform: uppercase;">{l.telTitle}</h2>
      <p class="sub" style="font-family: var(--font-mono); font-size: 14.5px; color: var(--gray-2); margin-top: 10px;">{l.telSub}</p>
    </div>
    <div class="telemetry-grid">
      <!-- Card 1 -->
      <div class="tel-card cyan-card">
        <div class="tel-card-top">
          <span class="tel-tag cyan">SYS_UPTIME</span>
          <span class="tel-status cyan-pulse" title="Online">● LIVE</span>
        </div>
        <div class="tel-body">
          <div class="tel-number"><span class="stat-counter" data-target="16">0</span><span class="tel-plus cyan">+</span></div>
          <div class="tel-title">{l.codingYears}</div>
          <p class="tel-desc">{l.codingDesc}</p>
        </div>
        <div class="tel-progress-box">
          <div class="tel-bar-header"><span>ACTIVITY_LEVEL</span><span>100%</span></div>
          <div class="tel-bar-bg"><div class="tel-bar-fill cyan-fill" style="width: 100%;"></div></div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="tel-card magenta-card">
        <div class="tel-card-top">
          <span class="tel-tag magenta">REPOSITORIES</span>
          <span class="tel-status magenta-pulse" title="Active">● SYNCED</span>
        </div>
        <div class="tel-body">
          <div class="tel-number"><span class="stat-counter" data-target="14">0</span><span class="tel-plus magenta">+</span></div>
          <div class="tel-title">{l.reposTitle}</div>
          <p class="tel-desc">{l.reposDesc}</p>
        </div>
        <div class="tel-progress-box">
          <div class="tel-bar-header"><span>PUBLIC_CODEBASE</span><span>88%</span></div>
          <div class="tel-bar-bg"><div class="tel-bar-fill magenta-fill" style="width: 88%;"></div></div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="tel-card amber-card">
        <div class="tel-card-top">
          <span class="tel-tag amber">DEV_STACK</span>
          <span class="tel-status amber-pulse" title="Ready">● MULTI_OS</span>
        </div>
        <div class="tel-body">
          <div class="tel-number"><span class="stat-counter" data-target="5">0</span><span class="tel-plus amber">+</span></div>
          <div class="tel-title">{l.langsTitle}</div>
          <p class="tel-desc">{l.langsDesc}</p>
        </div>
        <div class="tel-progress-box">
          <div class="tel-bar-header"><span>POLYGLOT_INDEX</span><span>92%</span></div>
          <div class="tel-bar-bg"><div class="tel-bar-fill amber-fill" style="width: 92%;"></div></div>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="tel-card green-card">
        <div class="tel-card-top">
          <span class="tel-tag green">VELOCITY</span>
          <span class="tel-status green-pulse" title="High Throughput">● OPTIMAL</span>
        </div>
        <div class="tel-body">
          <div class="tel-number"><span class="stat-counter" data-target="100">0</span><span class="tel-plus green">+</span></div>
          <div class="tel-title">{l.commitsTitle}</div>
          <p class="tel-desc">{l.commitsDesc}</p>
        </div>
        <div class="tel-progress-box">
          <div class="tel-bar-header"><span>THROUGHPUT</span><span>96%</span></div>
          <div class="tel-bar-bg"><div class="tel-bar-fill green-fill" style="width: 96%;"></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="timeline" style="padding: 60px 0 100px;">
    <div class="section-head" style="margin-bottom: 56px;">
      <p class="kicker" style="font-family: var(--font-hand); font-size: 30px; transform: rotate(-3deg); display: inline-block; color: var(--cyan);">the story so far // git commit log</p>
      <h2 style="font-family: var(--font-display); font-size: clamp(34px, 5.2vw, 56px); font-weight: 900; letter-spacing: -0.03em; text-transform: uppercase;">{l.histTitle}</h2>
      <p class="sub" style="font-family: var(--font-mono); font-size: 14.5px; color: var(--gray-2); margin-top: 10px;">{l.histSub}</p>
    </div>
    <div class="git-timeline-box">
      <div class="git-branch-list">
        <!-- Commit 2026 -->
        <div class="commit-row cyan-row">
          <div class="branch-marker cyan-marker">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/><circle cx="12" cy="12" r="5"/></svg>
          </div>
          <div class="commit-card">
            <div class="commit-header">
              <div class="commit-meta">
                <span class="commit-hash">commit #2026.04</span>
                <span class="commit-badge cyan-badge">● HEAD // ACTIVE</span>
              </div>
              <span class="commit-year cyan">2026</span>
            </div>
            <h3 class="commit-title">
              <span class="commit-icon cyan-bg">⚡</span>
              {l.t2026Title}
            </h3>
            <p class="commit-body">
              {l.t2026Body}
            </p>
            <div class="commit-tags">
              <span class="c-tag">#github</span>
              <span class="c-tag">#open-source</span>
              <span class="c-tag">#automation</span>
              <span class="c-tag">#cli-tools</span>
            </div>
          </div>
        </div>

        <!-- Commit 2023 -->
        <div class="commit-row magenta-row">
          <div class="branch-marker magenta-marker">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/><circle cx="12" cy="12" r="5"/></svg>
          </div>
          <div class="commit-card">
            <div class="commit-header">
              <div class="commit-meta">
                <span class="commit-hash">commit #2023.11</span>
                <span class="commit-badge magenta-badge">TAG: v3.0 // STABLE</span>
              </div>
              <span class="commit-year magenta">2023</span>
            </div>
            <h3 class="commit-title">
              <span class="commit-icon magenta-bg">🛠️</span>
              {l.t2023Title}
            </h3>
            <p class="commit-body">
              {l.t2023Body}
            </p>
            <div class="commit-tags">
              <span class="c-tag">#windows-11</span>
              <span class="c-tag">#localization</span>
              <span class="c-tag">#system-tools</span>
              <span class="c-tag">#batch-scripts</span>
            </div>
          </div>
        </div>

        <!-- Commit 2020 -->
        <div class="commit-row amber-row">
          <div class="branch-marker amber-marker">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/><circle cx="12" cy="12" r="5"/></svg>
          </div>
          <div class="commit-card">
            <div class="commit-header">
              <div class="commit-meta">
                <span class="commit-hash">commit #2020.08</span>
                <span class="commit-badge amber-badge">TAG: v2.0 // MOBILE</span>
              </div>
              <span class="commit-year amber">2020</span>
            </div>
            <h3 class="commit-title">
              <span class="commit-icon amber-bg">📱</span>
              {l.t2020Title}
            </h3>
            <p class="commit-body">
              {l.t2020Body}
            </p>
            <div class="commit-tags">
              <span class="c-tag">#android</span>
              <span class="c-tag">#kotlin</span>
              <span class="c-tag">#java</span>
              <span class="c-tag">#mobile-dev</span>
            </div>
          </div>
        </div>

        <!-- Commit 2016 -->
        <div class="commit-row green-row">
          <div class="branch-marker green-marker">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/><circle cx="12" cy="12" r="5"/></svg>
          </div>
          <div class="commit-card">
            <div class="commit-header">
              <div class="commit-meta">
                <span class="commit-hash">commit #2016.01</span>
                <span class="commit-badge green-badge">INIT: v1.0 // GENESIS</span>
              </div>
              <span class="commit-year green">2016</span>
            </div>
            <h3 class="commit-title">
              <span class="commit-icon green-bg">🚀</span>
              {l.t2016Title}
            </h3>
            <p class="commit-body">
              {l.t2016Body}
            </p>
            <div class="commit-tags">
              <span class="c-tag">#hello-world</span>
              <span class="c-tag">#foundations</span>
              <span class="c-tag">#algorithms</span>
              <span class="c-tag">#system-architecture</span>
            </div>
          </div>
        </div>

        <!-- Commit 2010 -->
        <div class="commit-row cyan-row">
          <div class="branch-marker cyan-marker">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/><circle cx="12" cy="12" r="5"/></svg>
          </div>
          <div class="commit-card">
            <div class="commit-header">
              <div class="commit-meta">
                <span class="commit-hash">commit #2010.02</span>
                <span class="commit-badge cyan-badge">ROOT: v0.1 // WEB_FOUNDATION</span>
              </div>
              <span class="commit-year cyan">2010</span>
            </div>
            <h3 class="commit-title">
              <span class="commit-icon cyan-bg">🌐</span>
              {l.t2010Title}
            </h3>
            <p class="commit-body">
              {l.t2010Body}
            </p>
            <div class="commit-tags">
              <span class="c-tag">#web-design</span>
              <span class="c-tag">#html-css</span>
              <span class="c-tag">#fullstack</span>
              <span class="c-tag">#databases</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="contact" style="max-width: 800px; margin: 80px auto 40px; padding: 0 26px;">
    <div style="background-color: var(--surface) !important; border: 2px solid var(--ink) !important; border-radius: 16px !important; box-shadow: 6px 6px 0px var(--ink) !important; padding: 40px 48px; position: relative; overflow: hidden;">
      
      <span style="font-family: var(--font-mono) !important; font-size: 11px !important; text-transform: uppercase !important; font-weight: bold !important; background: var(--magenta) !important; color: #fff !important; border: 2px solid var(--ink) !important; border-radius: 6px !important; padding: 4px 10px !important; display: inline-block !important; transform: rotate(-1deg) !important; margin-bottom: 24px !important;">
        {l.statusAvail}
      </span>
      
      <h2 style="font-family: var(--font-display) !important; font-size: clamp(28px, 4vw, 40px) !important; font-weight: 900 !important; line-height: 1.1 !important; margin-bottom: 14px !important; color: var(--ink) !important;">
        {l.contactHeading}
      </h2>
      <p style="font-size: 16px !important; line-height: 1.5 !important; color: var(--ink) !important; opacity: 0.85 !important; margin-bottom: 30px !important; max-width: 60ch !important;">
        {l.contactSub}
      </p>
      
      <div style="display: grid !important; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)) !important; gap: 18px !important; border-top: 1.5px dashed var(--line-strong) !important; border-bottom: 1.5px dashed var(--line-strong) !important; padding: 20px 0 !important; margin-bottom: 30px !important; font-family: var(--font-mono) !important; font-size: 13.5px !important; color: var(--ink) !important;">
        <div>
          <span style="opacity: 0.55 !important;">location:</span> Magdeburg / Remote
        </div>
        <div>
          <span style="opacity: 0.55 !important;">timezone:</span> GMT+2 (CET/EST compatible)
        </div>
        <div>
          <span style="opacity: 0.55 !important;">{l.responseLabel}:</span> {l.responseTime}
        </div>
      </div>
      
      <div class="connect-actions" style="display: flex !important; flex-wrap: wrap !important; gap: 16px !important; justify-content: flex-start !important;">
        <a href={`mailto:${l.contactBtnEmail}`} style="text-decoration: none !important; display: inline-flex !important; align-items: center !important; gap: 10px !important; border: 2px solid var(--ink) !important; box-shadow: 3px 3px 0px var(--ink) !important; padding: 12px 22px !important; border-radius: 8px !important; font-weight: bold !important; color: var(--ink) !important; background: var(--cyan) !important; transition: transform 0.1s, box-shadow 0.1s !important; font-family: var(--font-mono) !important; font-size: 13px !important; text-transform: uppercase !important;">
          <svg viewBox="0 0 24 24" fill="currentColor" style="width: 16px; height: 16px;"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          {l.contactBtnEmail}
        </a>
        <a href={getLocalizedPath('/contact')} style="text-decoration: none !important; display: inline-flex !important; align-items: center !important; gap: 10px !important; border: 2px solid var(--ink) !important; box-shadow: 3px 3px 0px var(--ink) !important; padding: 12px 22px !important; border-radius: 8px !important; font-weight: bold !important; color: var(--ink) !important; background: var(--paper) !important; transition: transform 0.1s, box-shadow 0.1s !important; font-family: var(--font-mono) !important; font-size: 13px !important; text-transform: uppercase !important;">
          {l.contactBtnGet}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width: 16px; height: 16px;"><path d="M5 12h13M12 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
