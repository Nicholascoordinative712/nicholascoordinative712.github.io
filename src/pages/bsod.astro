---
// Standalone BSOD screen easter egg page
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>System Error — BSOD</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    html, body {
      width: 100%;
      height: 100%;
      background-color: #0078d7;
      color: #ffffff;
      font-family: "Segoe UI", -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
      overflow: hidden;
      cursor: none; /* Hide cursor for realism */
    }

    /* CRT scanline effect on top */
    body::before {
      content: " ";
      display: block;
      position: absolute;
      top: 0; left: 0; bottom: 0; right: 0;
      background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.15) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
      z-index: 999;
      background-size: 100% 4px, 6px 100%;
      pointer-events: none;
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 6% 8%;
      display: flex;
      flex-direction: column;
      height: 100%;
      justify-content: flex-start;
    }

    .emoji {
      font-size: clamp(80px, 12vw, 150px);
      line-height: 1;
      font-weight: 300;
      margin-bottom: 30px;
      user-select: none;
    }

    .message {
      font-size: clamp(20px, 2.5vw, 29px);
      font-weight: 300;
      line-height: 1.4;
      margin-bottom: 25px;
      max-width: 900px;
    }

    .progress {
      font-size: clamp(18px, 2.2vw, 26px);
      font-weight: 300;
      margin-bottom: 45px;
    }

    .details-row {
      display: flex;
      align-items: flex-start;
      gap: 30px;
      margin-top: auto;
    }

    .qr-container {
      flex-shrink: 0;
      border: 4px solid #ffffff;
      background-color: #ffffff;
      padding: 8px;
      display: flex;
      justify-content: center;
      align-items: center;
      width: 146px;
      height: 146px;
    }
    .qr-container svg {
      width: 100% !important;
      height: 100% !important;
      display: block;
    }

    .info-text {
      font-size: clamp(13px, 1.4vw, 16px);
      line-height: 1.5;
      font-weight: 400;
    }

    .info-text a {
      color: #ffffff;
      text-decoration: underline;
    }

    .stop-code {
      margin-top: 15px;
      font-family: Consolas, monospace;
      font-size: clamp(12px, 1.3vw, 15px);
    }

    /* Glitch Animation */
    @keyframes glitch {
      0% { transform: translate(0) }
      20% { transform: translate(-2px, 2px) }
      40% { transform: translate(-2px, -2px) }
      60% { transform: translate(2px, 2px) }
      80% { transform: translate(2px, -2px) }
      100% { transform: translate(0) }
    }
    .glitching {
      animation: glitch 0.15s linear infinite;
    }

    /* Black screen reboot */
    .reboot-screen {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: #000000;
      z-index: 10000;
      display: none;
      color: #ffffff;
      font-family: Consolas, Monaco, monospace;
      padding: 40px;
      font-size: 16px;
    }

    .cursor {
      display: inline-block;
      width: 10px;
      height: 18px;
      background: #ffffff;
      animation: blink 0.8s infinite;
      vertical-align: middle;
    }
    @keyframes blink {
      0%, 100% { opacity: 0 }
      50% { opacity: 1 }
    }
  </style>
</head>
<body>
  <div class="container" id="bsod-container">
    <div class="emoji">:(</div>
    <div class="message">
      Your portfolio ran into a problem and needs to restart (probably because of a division by zero in my CSS). We're just collecting some debug logs and coffee stains, and then we'll reboot for you.
    </div>
    
    <div class="progress" id="progress-text">0% complete</div>

    <div class="details-row">
      <div class="qr-container">
        <svg xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 150 150" width="130" height="130">
          <title>QR Code</title>
          <desc>https://github.com/Almanex</desc>
          <rect style="fill:rgb(255, 255, 255);fill-opacity:1" x="0" y="0" width="150" height="150" />
          <g id="elements">
            <path style="fill:rgb(0, 0, 0)" d="M 0,0 l 6,0 0,6 -6,0 z M 6,0 l 6,0 0,6 -6,0 z M 12,0 l 6,0 0,6 -6,0 z M 18,0 l 6,0 0,6 -6,0 z M 24,0 l 6,0 0,6 -6,0 z M 30,0 l 6,0 0,6 -6,0 z M 36,0 l 6,0 0,6 -6,0 z M 54,0 l 6,0 0,6 -6,0 z M 78,0 l 6,0 0,6 -6,0 z M 96,0 l 6,0 0,6 -6,0 z M 108,0 l 6,0 0,6 -6,0 z M 114,0 l 6,0 0,6 -6,0 z M 120,0 l 6,0 0,6 -6,0 z M 126,0 l 6,0 0,6 -6,0 z M 132,0 l 6,0 0,6 -6,0 z M 138,0 l 6,0 0,6 -6,0 z M 144,0 l 6,0 0,6 -6,0 z M 0,6 l 6,0 0,6 -6,0 z M 36,6 l 6,0 0,6 -6,0 z M 48,6 l 6,0 0,6 -6,0 z M 54,6 l 6,0 0,6 -6,0 z M 66,6 l 6,0 0,6 -6,0 z M 72,6 l 6,0 0,6 -6,0 z M 84,6 l 6,0 0,6 -6,0 z M 90,6 l 6,0 0,6 -6,0 z M 96,6 l 6,0 0,6 -6,0 z M 108,6 l 6,0 0,6 -6,0 z M 144,6 l 6,0 0,6 -6,0 z M 0,12 l 6,0 0,6 -6,0 z M 12,12 l 6,0 0,6 -6,0 z M 18,12 l 6,0 0,6 -6,0 z M 24,12 l 6,0 0,6 -6,0 z M 36,12 l 6,0 0,6 -6,0 z M 54,12 l 6,0 0,6 -6,0 z M 60,12 l 6,0 0,6 -6,0 z M 66,12 l 6,0 0,6 -6,0 z M 84,12 l 6,0 0,6 -6,0 z M 96,12 l 6,0 0,6 -6,0 z M 108,12 l 6,0 0,6 -6,0 z M 120,12 l 6,0 0,6 -6,0 z M 126,12 l 6,0 0,6 -6,0 z M 132,12 l 6,0 0,6 -6,0 z M 144,12 l 6,0 0,6 -6,0 z M 0,18 l 6,0 0,6 -6,0 z M 12,18 l 6,0 0,6 -6,0 z M 18,18 l 6,0 0,6 -6,0 z M 24,18 l 6,0 0,6 -6,0 z M 36,18 l 6,0 0,6 -6,0 z M 48,18 l 6,0 0,6 -6,0 z M 54,18 l 6,0 0,6 -6,0 z M 66,18 l 6,0 0,6 -6,0 z M 78,18 l 6,0 0,6 -6,0 z M 108,18 l 6,0 0,6 -6,0 z M 120,18 l 6,0 0,6 -6,0 z M 126,18 l 6,0 0,6 -6,0 z M 132,18 l 6,0 0,6 -6,0 z M 144,18 l 6,0 0,6 -6,0 z M 0,24 l 6,0 0,6 -6,0 z M 12,24 l 6,0 0,6 -6,0 z M 18,24 l 6,0 0,6 -6,0 z M 24,24 l 6,0 0,6 -6,0 z M 36,24 l 6,0 0,6 -6,0 z M 60,24 l 6,0 0,6 -6,0 z M 72,24 l 6,0 0,6 -6,0 z M 78,24 l 6,0 0,6 -6,0 z M 96,24 l 6,0 0,6 -6,0 z M 108,24 l 6,0 0,6 -6,0 z M 120,24 l 6,0 0,6 -6,0 z M 126,24 l 6,0 0,6 -6,0 z M 132,24 l 6,0 0,6 -6,0 z M 144,24 l 6,0 0,6 -6,0 z M 0,30 l 6,0 0,6 -6,0 z M 36,30 l 6,0 0,6 -6,0 z M 48,30 l 6,0 0,6 -6,0 z M 60,30 l 6,0 0,6 -6,0 z M 78,30 l 6,0 0,6 -6,0 z M 84,30 l 6,0 0,6 -6,0 z M 90,30 l 6,0 0,6 -6,0 z M 96,30 l 6,0 